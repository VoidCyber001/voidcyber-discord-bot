# Copy this file to ".env" and fill in the values.

# Bot token (Discord Developer Portal → Bot → Reset Token)
DISCORD_TOKEN=your_bot_token_here

# Shared secret between the bot and VoidCyber.
# MUST match the value set on Vercel (DISCORD_BOT_SECRET).
# Generate a long random string: python -c "import secrets; print(secrets.token_urlsafe(48))"
DISCORD_BOT_SECRET=your_long_secret_string_here

# URL of the VoidCyber site the bot will call
VOIDCYBER_API_URL=https://voidcyber.net

# (Optional) Your Discord server ID — tells the bot which server to sync roles on.
GUILD_ID=
