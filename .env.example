# Copia questo file in ".env" e compila i valori.

# Token del bot (Discord Developer Portal → Bot → Reset Token)
DISCORD_TOKEN=il_tuo_token_del_bot

# Stringa segreta condivisa tra il bot e VoidCyber.
# DEVE essere identica a quella impostata su Cloudflare Pages (DISCORD_BOT_SECRET).
# Generane una lunga e casuale, es: python -c "import secrets; print(secrets.token_urlsafe(48))"
DISCORD_BOT_SECRET=metti_qui_una_stringa_lunga_e_segreta

# URL del sito che il bot deve chiamare
VOIDCYBER_API_URL=https://voidcyber.net

# (Opzionale) ID del tuo server Discord — indica al bot su quale server
# aggiornare i ruoli (usato dal loop di sincronizzazione).
GUILD_ID=
